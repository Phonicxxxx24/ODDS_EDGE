# ============================================================
#  OddsEdge — Credentials Template
# ============================================================
#
#  IMPORTANT: Do NOT put this file one level above sharp-detector/
#  The actual credentials file must be named  tokens.json  and
#  placed in the PARENT directory of sharp-detector/, like this:
#
#      your-project/               ← tokens.json goes HERE
#      └── sharp-detector/         ← this repo
#          ├── agent/
#          ├── backend/
#          └── ...
#
#  Why the parent directory?  All credential paths in the code
#  resolve to  ../tokens.json  (one level up from sharp-detector/).
#  This keeps secrets out of the repo entirely.
#
# ============================================================
#  HOW TO SET UP
# ============================================================
#
#  1. Copy this file one level ABOVE sharp-detector/ and rename it:
#
#       cp sharp-detector/.env.example tokens.json
#
#  2. Fill in each value below (remove the placeholder text).
#
#  3. Never commit tokens.json — it is already in .gitignore.
#
# ============================================================

# ── TxLINE credentials ────────────────────────────────────────────────────────
#
#  How to get these:
#    1. Call POST https://txline.txodds.com/auth/guest/start
#       → returns { "token": "<jwt>" }
#    2. Subscribe on-chain via the Anchor program
#       (SERVICE_LEVEL_ID = 1, free tier — World Cup + Int'l Friendlies)
#    3. Call POST https://txline.txodds.com/api/token/activate
#       → returns { "token": "<apiToken>" }
#  Both tokens must be sent as headers on every TxLINE request:
#    Authorization: Bearer <jwt>
#    X-Api-Token: <apiToken>
#
{
  "jwt": "YOUR_TXLINE_JWT_TOKEN_HERE",
  "apiToken": "YOUR_TXLINE_API_TOKEN_HERE",

  // ── OddsPapi credentials ───────────────────────────────────────────────────
  //
  //  How to get this:
  //    Sign up at https://oddspapi.io — free tier gives 250 total requests.
  //    Your API key is shown in the dashboard under Account > API Key.
  //  Sent as a query parameter: ?apiKey=<your_key>
  //
  
  "oddspapi_key": "YOUR_ODDSPAPI_KEY_HERE",

  // ── Gemini AI credentials (optional — for AI commentary feature) ───────────
  //
  //  How to get this:
  //    Go to https://aistudio.google.com/app/apikey and create a key.
  //    Alternatively, set the environment variable GEMINI_API_KEY instead
  //    of putting it here — the code checks the env var first.
  //
  
  "gemini_key": "YOUR_GEMINI_API_KEY_HERE"

}
